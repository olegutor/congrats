+/// Estimate raw (no frame / AES) Ghost capacity in payload bytes.
+///
+/// Same usable-coefficient / ratio model as [`estimate_capacity`], but the
+/// entire bit budget is payload — there is no salt/nonce/tag/CRC overhead.
+pub fn estimate_capacity_raw(img: &JpegImage) -> Result<usize, StegoError> {
+    if img.num_components() == 0 {
+        return Err(StegoError::NoLuminanceChannel);
+    }
+    let usable = count_nonzero_ac(img.dct_grid(0));
+    let max_frame_bits = (usable as f64 / MIN_CAPACITY_RATIO) as usize;
+    Ok(max_frame_bits / 8)
+}
